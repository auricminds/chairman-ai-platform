# apps/api — copy to .env.local and fill in real values

# Supabase (project-specific)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # NEVER expose to frontend

# OpenRouter (AI provider routing)
OPENROUTER_API_KEY=your-openrouter-api-key-here       # NEVER expose to frontend
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3-30b-a3b-instruct-2507

# Site clients (registered callers)
# CHAIRMAN_SITE_KEY=                                  # Generated per site in Supabase site_api_keys table

# Stripe (billing)
STRIPE_SECRET_KEY=sk_live_...                          # NEVER expose to frontend
STRIPE_WEBHOOK_SECRET=whsec_...                        # NEVER expose to frontend
STRIPE_PRICE_CHAIRMAN_PRIVATE_MONTHLY=price_...        # Stripe price ID for $10/mo
STRIPE_PRICE_CHAIRMAN_EXECUTIVE_MONTHLY=price_...      # Stripe price ID for $50/mo

# Public URLs (safe in env)
NEXT_PUBLIC_APP_URL=https://app.ai.chairmans.uk
NEXT_PUBLIC_API_URL=https://api.ai.chairmans.uk
